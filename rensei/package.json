{
  "name": "rensei",
  "version": "0.3.0",
  "type": "module",
  "description": "3D model rendering and JSCAD evaluation toolkit for AI agents — screenshot STL/JSCAD scripts from multiple angles using Three.js WebGPU in Node.js",
  "homepage": "https://github.com/remorses/rensei#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/rensei.git",
    "directory": "rensei"
  },
  "bugs": {
    "url": "https://github.com/remorses/rensei/issues"
  },
  "bin": "dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./modeling": {
      "types": "./dist/modeling.d.ts",
      "default": "./dist/modeling.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "docs",
    "skills"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" README.md docs skills && node --input-type=module -e \"import { cp, mkdir } from 'node:fs/promises'; await mkdir('skills/rensei', { recursive: true }); await mkdir('docs', { recursive: true }); await cp('../README.md', 'README.md'); await cp('../docs/image-to-jscad-workflow.md', 'docs/image-to-jscad-workflow.md'); await cp('../skills/rensei/SKILL.md', 'skills/rensei/SKILL.md');\" && pnpm build",
    "test": "vitest"
  },
  "keywords": [
    "jscad",
    "csg",
    "3d",
    "stl",
    "screenshot",
    "render",
    "webgpu",
    "three",
    "threejs",
    "headless",
    "node",
    "cli",
    "3d-printing",
    "parametric",
    "ai"
  ],
  "dependencies": {
    "@jscad/modeling": "^2.13.0",
    "@jscad/stl-serializer": "^2.1.23",
    "goke": "^6.8.0",
    "pngjs": "^7.0.0",
    "three": "^0.174.0",
    "tsx": "^4.20.5",
    "webgpu": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.174.0"
  }
}
